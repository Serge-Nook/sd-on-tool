[Desktop Entry]
Type=Application
Name=SD-ON Tool — Установщик
Name[en]=SD-ON Tool — Installer
Comment=Установка и удаление SD-ON Tool на Steam Deck
Comment[en]=Install and uninstall SD-ON Tool on Steam Deck
Exec=bash -c 'SCRIPT_DIR="$(dirname "$(readlink -f "%k")")"; bash "${SCRIPT_DIR}/sd-on-tool-setup.sh"'
Icon=system-software-install
Categories=Utility;System;
Terminal=false
StartupNotify=true
